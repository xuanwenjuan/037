SERVER_PORT=8080

DB_HOST=localhost
DB_PORT=5432
DB_USER=thz_user
DB_PASSWORD=thz_password
DB_NAME=thz_db

RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_QUEUE=thz_tasks
RABBITMQ_RESULT_QUEUE=thz_results
RABBITMQ_DIFF_QUEUE=thz_diff_tasks

WS_UPGRADE_BUFFER=1024

REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=86400
ENABLE_CACHE=true

METRICS_PORT=9090
ENABLE_METRICS=true
